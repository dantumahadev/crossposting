# Core Application Config
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
# 32-byte (64 char hex or base64) encryption key for AES-GCM token encryption at rest
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_SECRET_KEY=supersecretjwtkeyforfounderlabsmvp2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# Default to SQLite for zero-config local testing. Replace with PostgreSQL URL for production:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/founderlabs
DATABASE_URL=sqlite:///./founderlabs.db

# Redis & Queue Configuration
REDIS_URL=redis://localhost:6379/0

# Storage Provider (local or s3/r2)
STORAGE_PROVIDER=local
STORAGE_BUCKET=storage/media

# AI Copywriting APIs (Optional: if blank, fallback to high-quality smart rule-based generator)
OPENAI_API_KEY=
GEMINI_API_KEY=

# ==============================================================================
# SOCIAL PLATFORM OAUTH & API CREDENTIALS (100% Real APIs - No Mocks)
# ==============================================================================

# 1. Meta (Facebook Pages + Instagram Business/Professional)
# Create app at https://developers.facebook.com/
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8000/api/oauth/meta/callback

# 2. LinkedIn (Share on LinkedIn / UGC API)
# Create app at https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/oauth/linkedin/callback

# 3. Google / YouTube (YouTube Data API v3)
# Create project at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback
